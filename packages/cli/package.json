{
    "name": "@ds0/cli",
    "version": "0.1.0",
    "description": "CLI for DS0 — add components, init projects, export AI context",
    "license": "MIT",
    "type": "module",
    "bin": {
        "ds0": "./dist/index.js"
    },
    "main": "./dist/index.js",
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "typecheck": "tsc --noEmit",
        "lint": "eslint src/",
        "clean": "rm -rf dist .turbo"
    },
    "dependencies": {
        "commander": "^12.0.0",
        "prompts": "^2.4.2",
        "chalk": "^5.3.0",
        "ora": "^8.0.0",
        "fs-extra": "^11.0.0",
        "handlebars": "^4.7.0",
        "diff": "^5.0.0",
        "fast-glob": "^3.3.0",
        "node-fetch": "^3.3.0",
        "js-yaml": "^4.1.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/prompts": "^2.4.0",
        "@types/fs-extra": "^11.0.0",
        "@types/diff": "^5.0.0",
        "@types/js-yaml": "^4.0.0",
        "@types/node": "^22.0.0",
        "tsup": "^8.0.0",
        "typescript": "^5.0.0"
    },
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org/"
    },
    "keywords": [
        "cli",
        "design-system",
        "components",
        "tailwind",
        "ds0"
    ],
    "homepage": "https://ds0.systems",
    "bugs": {
        "url": "https://github.com/rwyatt2/ds0/issues"
    }
}