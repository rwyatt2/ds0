f family.","url":"/docs/foundations/typography","$ref":{"file":"foundations/typography.mdx"}},{"$id":"foundations/spacing.mdx","type":"page","name":"Spacing","description":"DS0 uses a 4px base unit spacing scale for consistent layouts across all components.","url":"/docs/foundations/spacing","$ref":{"file":"foundations/spacing.mdx"}},{"$id":"foundations/theming.mdx","type":"page","name":"Theming","description":"Create custom themes by overriding semantic tokens. Change your entire look with a single file.","url":"/docs/foundations/theming","$ref":{"file":"foundations/theming.mdx"}}],"$id":"foundations","$ref":{"metaFile":"foundations/meta.json"}},{"type":"folder","name":"Components","children":[{"$id":"components/overview.mdx","type":"page","name":"Component Overview","description":"All DS0 components organized by category.","url":"/docs/components/overview","$ref":{"file":"components/overview.mdx"}},{"$id":"_0","type":"separator","name":"Actions"},{"$id":"components/button.mdx","type":"page","name":"Button","description":"Triggers an action or event, such as submitting a form, opening a dialog, or performing a destructive operation.","url":"/docs/components/button","$ref":{"file":"components/button.mdx"}},{"$id":"components/icon-button.mdx","type":"page","name":"IconButton","description":"A button containing only an icon.","url":"/docs/components/icon-button","$ref":{"file":"components/icon-button.mdx"}},{"$id":"components/toggle.mdx","type":"page","name":"Toggle","description":"A two-state button that can be on or off, like a standalone toggle in a toolbar.","url":"/docs/components/toggle","$ref":{"file":"components/toggle.mdx"}},{"$id":"components/toggle-group.mdx","type":"page","name":"ToggleGroup","description":"A set of two-state buttons where one or more can be toggled on.","url":"/docs/components/toggle-group","$ref":{"file":"components/toggle-group.mdx"}},{"$id":"_1","type":"separator","name":"Data Input"},{"$id":"components/text-field.mdx","type":"page","name":"TextField","description":"A single-line text input for collecting short-form user data like names, emails, or search queries.","url":"/docs/components/text-field","$ref":{"file":"components/text-field.mdx"}},{"$id":"components/text-area.mdx","type":"page","name":"TextArea","description":"A multi-line text input for collecting longer-form content like comments, descriptions, or messages.","url":"/docs/components/text-area","$ref":{"file":"components/text-area.mdx"}},{"$id":"components/select.mdx","type":"page","name":"Select","description":"A dropdown menu for selecting a single option from a list.","url":"/docs/components/select","$ref":{"file":"components/select.mdx"}},{"$id":"components/checkbox.mdx","type":"page","name":"Checkbox","description":"A toggle control that allows the user to select or deselect an option.","url":"/docs/components/checkbox","$ref":{"file":"components/checkbox.mdx"}},{"$id":"components/radio-group.mdx","type":"page","name":"RadioGroup","description":"A set of mutually exclusive options where the user selects exactly one.","url":"/docs/components/radio-group","$ref":{"file":"components/radio-group.mdx"}},{"$id":"components/switch.mdx","type":"page","name":"Switch","description":"A toggle control for settings that take immediate effect, like enabling/disabling a feature.","url":"/docs/components/switch","$ref":{"file":"components/switch.mdx"}},{"$id":"components/slider.mdx","type":"page","name":"Slider","description":"A draggable control for selecting a numeric value within a range.","url":"/docs/components/slider","$ref":{"file":"components/slider.mdx"}},{"$id":"components/form.mdx","type":"page","name":"Form","description":"Composition component that structures form fields, labels, descriptions, errors, and actions.","url":"/docs/components/form","$ref":{"file":"components/form.mdx"}},{"$id":"_2","type":"separator","name":"Data Display"},{"$id":"components/badge.mdx","type":"page","name":"Badge","description":"Small visual indicator for status, counts, or categories.","url":"/docs/components/badge","$ref":{"file":"components/badge.mdx"}},{"$id":"components/avatar.mdx","type":"page","name":"Avatar","description":"Displays a user's profile image, initials, or a fallback icon.","url":"/docs/components/avatar","$ref":{"file":"components/avatar.mdx"}},{"$id":"components/card.mdx","type":"page","name":"Card","description":"A contained surface for grouping related information and actions.","url":"/docs/components/card","$ref":{"file":"components/card.mdx"}},{"$id":"components/table.mdx","type":"page","name":"Table","description":"Displays tabular data with consistent styling using native HTML table elements.","url":"/docs/components/table","$ref":{"file":"components/table.mdx"}},{"$id":"components/accordion.mdx","type":"page","name":"Accordion","description":"A vertically stacked set of collapsible sections.","url":"/docs/components/accordion","$ref":{"file":"components/accordion.mdx"}},{"$id":"_3","type":"separator","name":"Feedback"},{"$id":"components/alert.mdx","type":"page","name":"Alert","description":"A non-modal, inline message for status, warnings, and errors.","url":"/docs/components/alert","$ref":{"file":"components/alert.mdx"}},{"$id":"components/toast.mdx","type":"page","name":"Toast","description":"A temporary, non-blocking notification that appears at the edge of the screen and auto-dismisses.","url":"/docs/components/toast","$ref":{"file":"components/toast.mdx"}},{"$id":"components/progress.mdx","type":"page","name":"Progress","description":"A visual bar indicating the completion status of a task or process.","url":"/docs/components/progress","$ref":{"file":"components/progress.mdx"}},{"$id":"components/spinner.mdx","type":"page","name":"Spinner","description":"Animated loading indicator.","url":"/docs/components/spinner","$ref":{"file":"components/spinner.mdx"}},{"$id":"components/skeleton.mdx","type":"page","name":"Skeleton","description":"Placeholder loading indicator.","url":"/docs/components/skeleton","$ref":{"file":"components/skeleton.mdx"}},{"$id":"_4","type":"separator","name":"Layout"},{"$id":"components/stack.mdx","type":"page","name":"Stack","description":"Flex layout for vertical or horizontal stacking.","url":"/docs/components/stack","$ref":{"file":"components/stack.mdx"}},{"$id":"components/grid.mdx","type":"page","name":"Grid","description":"CSS Grid-based layout.","url":"/docs/components/grid","$ref":{"file":"components/grid.mdx"}},{"$id":"components/container.mdx","type":"page","name":"Container","description":"Centers content with max-width and padding.","url":"/docs/components/container","$ref":{"file":"components/container.mdx"}},{"$id":"components/divider.mdx","type":"page","name":"Divider","description":"Visual separator between content.","url":"/docs/components/divider","$ref":{"file":"components/divider.mdx"}},{"$id":"components/aspect-ratio.mdx","type":"page","name":"AspectRatio","description":"Constrains children to a specific width-to-height ratio.","url":"/docs/components/aspect-ratio","$ref":{"file":"components/aspect-ratio.mdx"}},{"$id":"_5","type":"separator","name":"Navigation"},{"$id":"components/tabs.mdx","type":"page","name":"Tabs","description":"Organizes content into multiple panels, with only one panel visible at a time.","url":"/docs/components/tabs","$ref":{"file":"components/tabs.mdx"}},{"$id":"components/breadcrumb.mdx","type":"page","name":"Breadcrumb","description":"Shows the user's current location within a navigational hierarchy.","url":"/docs/components/breadcrumb","$ref":{"file":"components/breadcrumb.mdx"}},{"$id":"components/pagination.mdx","type":"page","name":"Pagination","description":"Navigation controls for moving between pages of content.","url":"/docs/components/pagination","$ref":{"file":"components/pagination.mdx"}},{"$id":"components/link.mdx","type":"page","name":"Link","description":"An anchor element for navigating to a URL or page.","url":"/docs/components/link","$ref":{"file":"components/link.mdx"}},{"$id":"_6","type":"separator","name":"Overlay"},{"$id":"components/dialog.mdx","type":"page","name":"Dialog","description":"A modal overlay that interrupts the user with important content and expects a response.","url":"/docs/components/dialog","$ref":{"file":"components/dialog.mdx"}},{"$id":"components/popover.mdx","type":"page","name":"Popover","description":"A non-modal overlay anchored to a trigger.","url":"/docs/components/popover","$ref":{"file":"components/popover.mdx"}},{"$id":"components/tooltip.mdx","type":"page","name":"Tooltip","description":"A brief text label that appears on hover or focus.","url":"/docs/components/tooltip","$ref":{"file":"components/tooltip.mdx"}},{"$id":"components/drawer.mdx","type":"page","name":"Drawer","description":"A slide-out panel attached to an edge of the screen.","url":"/docs/components/drawer","$ref":{"file":"components/drawer.mdx"}},{"$id":"_7","type":"separator","name":"Typography"},{"$id":"components/heading.mdx","type":"page","name":"Heading","description":"Renders semantic heading elements (h1–h6) with consistent styling and visual hierarchy.","url":"/docs/components/heading","$ref":{"file":"components/heading.mdx"}},{"$id":"components/text.mdx","type":"page","name":"Text","description":"Renders styled text content with consistent typography.","url":"/docs/components/text","$ref":{"file":"components/text.mdx"}},{"$id":"components/label.mdx","type":"page","name":"Label","description":"Accessible label for form inputs with consistent styling.","url":"/docs/components/label","$ref":{"file":"components/label.mdx"}},{"$id":"components/code.mdx","type":"page","name":"Code","description":"Renders inline or block code with monospace styling.","url":"/docs/components/code","$ref":{"file":"components/code.mdx"}}],"$id":"components","$ref":{"metaFile":"components/meta.json"}},{"type":"folder","name":"Patterns","children":[{"$id":"patterns/forms.mdx","type":"page","name":"Form Patterns","description":"Common form patterns and best practices with DS0 components.","url":"/docs/patterns/forms","$ref":{"file":"patterns/forms.mdx"}},{"$id":"patterns/data-display.mdx","type":"page","name":"Data Display Patterns","description":"Patterns for displaying data using DS0 components.","url":"/docs/patterns/data-display","$ref":{"file":"patterns/data-display.mdx"}},{"$id":"patterns/navigation.mdx","type":"page","name":"Navigation Patterns","description":"Common navigation patterns with DS0 components.","url":"/docs/patterns/navigation","$ref":{"file":"patterns/navigation.mdx"}},{"$id":"patterns/feedback.mdx","type":"page","name":"Feedback Patterns","description":"Common feedback and notification patterns with DS0 components.","url":"/docs/patterns/feedback","$ref":{"file":"patterns/feedback.mdx"}}],"$id":"patterns","$ref":{"metaFile":"patterns/meta.json"}},{"type":"folder","name":"Guides","children":[{"$id":"guides/ai-usage.mdx","type":"page","name":"Using DS0 with AI","description":"How to give AI tools full knowledge of DS0 for accurate component generation.","url":"/docs/guides/ai-usage","$ref":{"file":"guides/ai-usage.mdx"}},{"$id":"guides/figma-workflow.mdx","type":"page","name":"Figma Workflow","description":"How DS0 syncs design tokens and components between code and Figma.","url":"/docs/guides/figma-workflow","$ref":{"file":"guides/figma-workflow.mdx"}},{"$id":"guides/accessibility.mdx","type":"page","name":"Accessibility","description":"DS0 is built with accessibility as a core requirement, not an afterthought.","url":"/docs/guides/accessibility","$ref":{"file":"guides/accessibility.mdx"}},{"$id":"guides/contributing.mdx","type":"page","name":"Contributing","description":"How to contribute to DS0 — components, tokens, documentation, and more.","url":"/docs/guides/contributing","$ref":{"file":"guides/contributing.mdx"}}],"$id":"guides","$ref":{"metaFile":"guides/meta.json"}}]},"children":"$L3"}]]}],"loading":null,"isPartial":false}
